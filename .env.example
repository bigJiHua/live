# 站点标题
VITE_APP_TITLE=Golden Finance

# 站点描述
VITE_APP_DESCRIPTION=个人财务管理工具

# 站点域名
VITE_SITE_URL=http://localhost

# 运行端口
VITE_PORT=5173

# Demo 模式开关（开启时显示演示提示、备案信息等辅助内容）
VITE_APP_DEMO=true

# API 基础地址
VITE_API_BASE_URL=http://localhost:your_Port/api/

# 文件上传基础路径
VITE_FILE_BASE_URL=http://localhost:your_Port/api/public

# 备案信息（仅非演示模式显示）
VITE_ICP_NUMBER=演ICP备XXXXXXXXX号
VITE_PSB_NUMBER=演公网安备XXXXXXXXX号

# 站点品牌
VITE_BRAND_NAME=MyBrand
VITE_POWERED_BY=MyTeam
VITE_COPYRIGHT_START=2021

# 演示模式默认账密（仅 VITE_APP_DEMO=true 时生效）
VITE_LOGIN_USERNAME=admin
VITE_LOGIN_PASSWORD=Admin123ok.
