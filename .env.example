# ============================================
# 系统初始化配置
# ============================================
# 是否启用初始化（首次启动后自动设为 false）
# true = 启用初始化检测，false = 跳过初始化
# 首次部署时设为 true，初始化完成后自动改为 false
INIT_ENABLE=false

# 初始管理员账户配置（仅在 INIT_ENABLE=true 时生效）
# 如果不设置，将使用默认值: admin / admin123
INIT_ADMIN_USER=admin
INIT_ADMIN_PASS=your_secure_password
INIT_ADMIN_EMAIL=admin@example.com

# ============================================
# 服务器配置
# ============================================
NODE_ENV=development
PORT=3001

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=live

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session 配置
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# 密码加密配置
# BCRYPT_SALT_ROUNDS: bcrypt 盐轮数 (用于密码加密强度)
# 说明:
#   - 数字越大,加密越安全,但计算时间越长
#   - 推荐值: 开发环境 10, 生产环境 12-15
#   - 例如: 10 表示进行 2^10 = 1024 轮哈希运算
#   - 安全性: 每增加 1,计算时间翻倍,破解难度指数级增加
#   - 性能影响: 10 约需 100-200ms, 15 约需 3-5 秒
BCRYPT_SALT_ROUNDS=10

# 邮件配置
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-app-password

# 前端 URL
FRONTEND_URL=http://localhost:3000

# 应用名称
APP_NAME=生活管理系统
